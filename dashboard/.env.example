# Free key from https://www.alphavantage.co/support/#api-key — powers the التغيرات الاقتصادية
# card (oil / natural gas / gold / USD-SAR). Free tier = 25 requests/day, so results are
# cached ~4h. WITHOUT this key the card automatically falls back to the World Bank API
# (keyless macro indicators — inflation / GDP growth), so it still shows REAL data.
VITE_ALPHAVANTAGE_API_KEY=

# Local Ollama server powering the "AI Analyze" button in each widget (gpt-oss:20b by default).
# Also enriches official statements (summary/category/urgency/entities). Optional — both
# default in code; falls back to a keyword heuristic when unavailable.
# VITE_OLLAMA_URL=http://localhost:11434
# VITE_OLLAMA_MODEL=gpt-oss:20b

# ── Backend (server-side) — used by the /api/statements proxy, NOT the browser ──
# Free, approved appname for the ReliefWeb API v2 (register at
# https://apidoc.reliefweb.int/parameters#appname). Without it ReliefWeb 403s and the
# proxy simply serves GDELT + official RSS instead. No VITE_ prefix — read via process.env.
# RELIEFWEB_APPNAME=your-approved-appname

# ── Security Threats section ─────────────────────────────────────────────────
# ReliefWeb (frontend — public appname, ReliefWeb v2 is CORS-open). Same approved
# appname as above works. Missing → the Security card shows a "ReliefWeb appname
# missing" notice and simply omits ReliefWeb events (no mock).
VITE_RELIEFWEB_APP_NAME=

# ACLED conflict events (BACKEND ONLY — credentials never reach the browser).
# Register free at https://developer.acleddata.com. Provide EITHER a pre-generated
# access token, OR email + password (OAuth2 password grant). Missing → the card
# shows an "ACLED not configured" notice and omits conflict events (no mock).
# ACLED_ACCESS_TOKEN=
# ACLED_EMAIL=
# ACLED_PASSWORD=
# ACLED_CLIENT_ID=acled
# ACLED_CLIENT_SECRET=
